# ─── DATABASE (Railway auto-sets DATABASE_URL via MySQL plugin) ───
DATABASE_URL=mysql://root:password@host.railway.internal:3306/railway

# ─── JWT ──────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_long_random_string

# ─── GOOGLE OAUTH ─────────────────────────────────────────────────
# Create at: console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://YOUR-APP.railway.app/api/oauth/callback
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# Your Google email — this account gets admin/dashboard access
ADMIN_EMAIL=you@gmail.com

# ─── OPTIONAL: Twilio SMS ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+15551234567

# ─── Email (Resend preferred if RESEND_API_KEY is set) ─────────────
# Railway: add RESEND_API_KEY in Variables (same name — no typos).
# Applicant confirmation uses sendEmail() → Resend first, then SendGrid.
RESEND_API_KEY=
# Required for production: an address on a domain you verified in Resend (dashboard → Domains).
# If unset, code falls back to onboarding@resend.dev (limited; set RESEND_FROM_EMAIL for real sends).
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=National Solar Sales Academy

# ─── OPTIONAL: SendGrid (fallback if RESEND_API_KEY is unset) ────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@nationalsolarsalesacademy.com
SENDGRID_FROM_NAME=National Solar Sales Academy

# ─── OPTIONAL: Manus/WebDev Forge (resume upload + owner ping) ────
# If your deployment already has these, resumes upload through Forge; no AWS needed.
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=

# ─── OPTIONAL: Rate limits (Helmet + limiters always on; tune these) ─
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_API_MAX=600
# RATE_LIMIT_OAUTH_MAX=60

# ─── OPTIONAL: Calendly ───────────────────────────────────────────
CALENDLY_API_KEY=
CALENDLY_SCHEDULING_URL=https://calendly.com/yourorg/interview
CALENDLY_EVENT_TYPE_URI=
